# =============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - GROW Deck Automator SEIDOR Perú
# =============================================================================
# Copia este archivo como .env y completa los valores
# =============================================================================

# API Key de Google Gemini para el Chatbot IA de Preventa SAP
# Obtén tu API Key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu-api-key-de-gemini-aqui

# Modelo de Gemini (opcional, por defecto gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Flask configuration
FLASK_SECRET_KEY=cambiar-esta-clave-por-una-segura
FLASK_DEBUG=0

# Token de autenticación para endpoints de API (si se deja vacío, la autenticación está deshabilitada)
API_TOKEN=

# Base de datos y archivos
DB_NAME=proposals.db
OUTPUT_DIR=generated_decks

# Rate limiting (opcional, valores por defecto)
# RATE_LIMIT_WINDOW=60
# RATE_LIMIT_MAX=30
